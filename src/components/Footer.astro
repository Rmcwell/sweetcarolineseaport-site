---
const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Availability", href: "/availability" },
  { name: "Photos", href: "/photos" },
  { name: "Location", href: "/location" },
  { name: "Contact", href: "#contact" }
];

const pills = ["Tropical Destination", "Monthly Rental", "Fully Furnished"];

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-brand-secondary text-white pt-20 pb-10">
  <div class="max-w-6xl mx-auto px-6 lg:px-10">
    <div>
      <div class="flex items-center gap-4 mb-5">
        <span class="block h-px w-10 bg-brand-primary shrink-0"></span>
        <span class="text-[9px] tracking-[0.35em] uppercase text-brand-primary">
          Est. Key West, FL &nbsp;·&nbsp; 28 Night Minimum
        </span>
      </div>

      <h2
        class="text-white leading-tight tracking-tight text-3xl sm:text-4xl lg:text-5xl mb-3"
      >
        Sweet <em class="text-brand-primary">Caroline</em> Seaport
      </h2>

      <p class="italic text-white/40 text-base leading-relaxed max-w-md">
        "Historic charm meets modern luxury at the heart of the Seaport
        district."
      </p>

      <ul class="flex flex-wrap gap-2 mt-6 list-none p-0 m-0">
        {
          pills.map((p) => (
            <li class="border border-white/12 rounded-sm px-2.5 py-1 text-[10px] tracking-[0.15em] uppercase text-white/35">
              {p}
            </li>
          ))
        }
      </ul>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-3 gap-y-12 border-t border-white/8 mt-14 pt-14"
    >
      <div class="sm:pr-12 text-center">
        <span
          class="block text-[9px] tracking-[0.35em] uppercase text-white/25 mb-7"
          >Minimum Stay</span
        >
        <div
          class="border border-brand-primary/20 rounded bg-brand-primary/4 p-6 text-center"
        >
          <p class="text-brand-primary text-6xl leading-none mb-1 m-0">28</p>
          <p
            class="text-[9px] tracking-[0.3em] uppercase text-white/30 mb-5 mt-1"
          >
            Night Minimum
          </p>
          <a
            href="/availability"
            class="block w-full py-2.5 bg-brand-primary text-brand-secondary text-[10px] tracking-[0.25em] uppercase rounded-sm no-underline transition-opacity duration-200 hover:opacity-85"
          >
            Check Availability
          </a>
        </div>
      </div>

      <div class="sm:border-l sm:border-white/[0.07] text-center">
        <span
          class="block text-[9px] tracking-[0.35em] uppercase text-white/25 mb-7"
          >Explore</span
        >
        <ul class="flex flex-col gap-3.5 list-none p-0 m-0">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/55 text-sm tracking-[0.01em] no-underline transition-colors duration-200 hover:text-brand-primary"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="sm:border-l sm:border-white/[0.07] sm:pl-12 text-center">
        <span
          class="block text-[9px] tracking-[0.35em] uppercase text-white/25 mb-7"
          >Inquiries</span
        >

        <div class="mb-7">
          <p
            class="text-[9px] tracking-[0.3em] uppercase text-white/25 mb-1.5 m-0"
          >
            Email
          </p>
          <a
            href="mailto:info@sweetcarolineseaport.com"
            class="text-[13px] text-white/75 no-underline leading-relaxed block transition-colors duration-200 hover:text-brand-primary"
          >
            info@sweetcarolineseaport.com
          </a>
        </div>

        <div class="mb-7">
          <p
            class="text-[9px] tracking-[0.3em] uppercase text-white/25 mb-1.5 m-0"
          >
            Phone
          </p>
          <a
            href="tel:+13055551234"
            class="text-[15px] text-white/75 no-underline block transition-colors duration-200 hover:text-brand-primary"
          >
            (305) 555-1234
          </a>
        </div>

        <div>
          <p
            class="text-[9px] tracking-[0.3em] uppercase text-white/25 mb-1.5 m-0"
          >
            Address
          </p>
          <p class="text-[13px] text-white/75 leading-relaxed m-0">
            724 Caroline St.<br />
            Key West, FL 33040
          </p>
        </div>
      </div>
    </div>

    <div
      class="border-t border-white/[0.07] mt-16 pt-7 flex flex-col sm:flex-row justify-between items-center gap-6"
    >
      <p
        class="text-[11px] tracking-[0.25em] uppercase text-white/20 m-0 text-center sm:text-left"
      >
        &copy; {currentYear} Sweet Caroline Seaport
      </p>
      <div class="flex gap-6">
        <a
          href="/terms"
          class="text-[11px] tracking-[0.2em] uppercase text-white/20 no-underline transition-colors duration-200 hover:text-white/50"
        >
          Terms
        </a>
        <a
          href="/privacy"
          class="text-[11px] tracking-[0.2em] uppercase text-white/20 no-underline transition-colors duration-200 hover:text-white/50"
        >
          Privacy
        </a>
      </div>
    </div>
  </div>
</footer>
