---
const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Availability", href: "/availability" },
  { name: "Photos", href: "/photos" },
  { name: "Location", href: "/location" },
  { name: "Contact", href: "#contact" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-secondary text-white pt-12 pb-6">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-12">
    <div class="space-y-4">
      <h2 class="text-2xl font-serif tracking-wide text-brand-primary">
        Sweet Caroline Seaport
      </h2>
      <p class="text-sm leading-relaxed text-slate-300 max-w-xs">
        Experience the historic charm of the Seaport District. Luxury residences
        tailored for extended stays of 28 nights or more.
      </p>
    </div>

    <div class="md:justify-self-center">
      <h3
        class="text-sm uppercase tracking-widest font-bold mb-4 text-brand-primary"
      >
        Navigation
      </h3>
      <ul class="space-y-2 text-sm">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="hover:text-brand-accent transition-colors"
              >
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="space-y-4">
      <h3
        class="text-sm uppercase tracking-widest font-bold text-brand-primary"
      >
        Get In Touch
      </h3>
      <div class="text-sm space-y-3">
        <p class="flex items-center gap-2">
          <svg
            class="w-4 h-4 shrink-0 text-brand-accent"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          <a
            href="mailto:info@sweetcarolineseaport.com"
            class="hover:underline hover:text-brand-accent"
          >
            info@sweetcarolineseaport.com
          </a>
        </p>
        <p class="flex items-start gap-2 text-slate-300">
          <svg
            class="w-4 h-4 shrink-0 mt-0.5 text-brand-accent"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span>724 Caroline St.<br />Key West, FL 33040</span>
        </p>
      </div>
    </div>
  </div>

  <div class="mt-12 pt-6 border-t border-white/10">
    <div
      class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center text-xs text-slate-400 gap-4"
    >
      <p>&copy; 2026 Sweet Caroline Seaport. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/terms" class="hover:text-white transition-colors"
          >Terms of Service</a
        >
        <a href="/privacy" class="hover:text-white transition-colors"
          >Privacy Policy</a
        >
      </div>
    </div>
  </div>
</footer>
