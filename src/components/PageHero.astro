---
import { Image } from "astro:assets";
import beachImage from "../assets/beach.jpg"

interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  tagline,
} = Astro.props;
---

<section
  class={`relative overflow-hidden w-full h-[50vh] min-h-87.5`}
>
  <!-- Background image -->
  <Image
    src={beachImage}
    alt="Sweet Caroline Seaport — Key West vacation rental"
    width={1920}
    height={1080}
    class="absolute inset-0 w-full h-full object-cover -scale-x-100"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-linear-to-r from-black/80 via-black/60 to-black/20"></div>

  <!-- Content -->
  <div class="relative z-10 h-full flex items-center">
    <div class="container mx-auto px-6">
      <div id="page-hero-content" class="max-w-2xl opacity-0 translate-y-8">
        {tagline && (
          <p class="text-sm tracking-[0.35em] uppercase text-white/70 mb-4">
            {tagline}
          </p>
        )}
        <h1 class="text-5xl md:text-7xl leading-tight text-white mb-6">
          {title}
        </h1>
        <div class="w-16 h-px bg-amber-400 mb-6"></div>
        {subtitle && (
          <p class="text-lg text-white/80 max-w-lg leading-relaxed">
            {subtitle}
          </p>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  #page-hero-content {
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  #page-hero-content.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const content = document.getElementById("page-hero-content");
  if (content) {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        content.classList.add("visible");
      });
    });
  }
</script>