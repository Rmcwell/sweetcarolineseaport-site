---
//Update this variable with your actual Basin form ID for the form to work correctly.
const basinURL = "https://usebasin.com/f/3519717384b0";

//Update this variable with your actual Cloudflare Turnstile site key for the widget to work correctly.
//Also check the index to ensure the script tag for the Cloudflare Turnstile widget is included in the head of your layout.
const turnstileSiteKey = "0x4AAAAAACv6SgHUpnc63a6N";
---

  <div class="w-full max-w-2xl rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
    <form id="contact-form" action={basinURL} method="POST" class="space-y-5">
        <div>
          <label for="name" class="mb-1 block text-sm font-medium text-gray-700">
            Full Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="John Doe"
            required
            class="contact-input focus:border-brand-primary focus:ring-brand-primary w-full rounded-lg border border-gray-300 px-4 py-2 transition-all outline-none"
          />
        </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        <div>
          <label for="email" class="mb-1 block text-sm font-medium text-gray-700">
            Email Address <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="you@example.com"
            required
            class="contact-input focus:border-brand-primary focus:ring-brand-primary w-full rounded-lg border border-gray-300 px-4 py-2 transition-all outline-none"
          />
        </div>

        <div>
          <label for="phone" class="mb-1 block text-sm font-medium text-gray-700">
            Phone Number
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="(555) 000-0000"
            class="contact-input focus:border-brand-primary focus:ring-brand-primary w-full rounded-lg border border-gray-300 px-4 py-2 transition-all outline-none"
          />
        </div>
      </div>

      <div>
        <label for="message" class="mb-1 block text-sm font-medium text-gray-700">
          Message <span class="text-red-500">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          placeholder="How can we help?"
          required
          class="contact-input focus:border-brand-primary focus:ring-brand-primary w-full resize-none rounded-lg border border-gray-300 px-4 py-2 transition-all outline-none"
        ></textarea>
      </div>

      <p class="text-xs text-gray-400 italic">
        Fields marked with <span class="text-red-500">*</span> are required.
      </p>

      <!-- Cloudflare Turnstile widget -->
      <div
        class="cf-turnstile"
        data-sitekey={turnstileSiteKey}
        data-callback="turnstileFinished"
        data-theme="light"
      >
      </div>

      <!-- Hidden honeypot field. Needs to have the same name as the one configured in Basin to work correctly. -->
      <div class="absolute top-0 -left-600 h-0 overflow-hidden" aria-hidden="true">
        <label for="_botvortex">Leave this field empty</label>
        <input type="text" id="_botvortex" name="_botvortex" tabindex="-1" autocomplete="off" />
      </div>

      <button
        type="submit"
        id="submit-btn"
        disabled
        class="w-full rounded-lg bg-indigo-600 px-6 py-3 font-semibold text-white shadow-md transition-all duration-200 hover:bg-indigo-700 hover:shadow-lg active:scale-[0.98] active:transform disabled:cursor-not-allowed disabled:bg-gray-300 disabled:shadow-none"
      >
        Send Message
      </button>
    </form>
  </div>

<script>
  declare global {
    interface Window {
      turnstileFinished?: () => void;
    }
  }

  let isTurnstileVerified = false;
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const requiredInputs = form.querySelectorAll("[required]") as NodeListOf<
    HTMLInputElement | HTMLTextAreaElement
  >;

  // Function called by Cloudflare when check is passed
  window.turnstileFinished = function () {
    isTurnstileVerified = true;
    checkFormValidity();
  };

  const checkFormValidity = () => {
    // Check if all required fields have values
    const allFieldsFilled = Array.from(requiredInputs).every((input) => input.value.trim() !== "");

    // Only enable if fields are filled AND turnstile is verified
    submitBtn.disabled = !(allFieldsFilled && isTurnstileVerified);
  };

  // Add event listeners to all required inputs
  requiredInputs.forEach((input) => {
    input.addEventListener("input", checkFormValidity);
  });
</script>
