const pageTitle = "About";
const metaDescription =
  "Learn about our luxury Key West vacation rental property.";
---

<Layout title={pageTitle} description={metaDescription}>
  <PageHero
    title="About the Property"
    subtitle="Your private oasis in the heart of Old Town Key West. Choose from two beautifully renovated units with a 28-night minimum stay."
    tagline="Sweet Caroline Seaport"
  />

  <Section class="max-w-4xl text-center">
    <SectionHeader title="Historic Seaport Living" tagline="The Property">
      <p class="leading-relaxed text-lg mb-12 opacity-80">
        This fully renovated house is located in the historic seaport with many
        highly rated restaurants and shops. A quick 5-minute walk will take you
        to the iconic Duval Street, the heart of Key West. Three-dimensional
        ceilings throughout with indirect LED lighting, fully equipped kitchens,
        ceiling fans, and new furniture in every room.
      </p>
    </SectionHeader>

    <div class="grid md:grid-cols-2 gap-8">
      <div
        class="about-left bg-white rounded-xl shadow-md p-8 text-center opacity-0 -translate-x-8 transition-all duration-700 ease-out"
      >
        <p class="text-xs tracking-[0.3em] uppercase text-brand-accent mb-2">
          Unit One
        </p>
        <h3 class="font-headers text-2xl mb-1">First Floor</h3>
        <div class="w-8 h-0.5 rounded-full bg-brand-accent mx-auto my-3"></div>
        <p class="text-sm opacity-60 mb-4">
          8 Guests · 3 Bedrooms · 5 Beds · 3 Baths
        </p>
        <div class="text-sm space-y-1.5 opacity-80">
          <p>Bedroom 1: 1 King Bed</p>
          <p>Bedroom 2: 1 Queen Bed</p>
          <p>Bedroom 3: 2 Twin Beds</p>
          <p>Common Space: 1 Sofa Bed</p>
          <p class="text-xs pt-3 opacity-60">4 stairs to front porch entry</p>
        </div>
      </div>

      <div
        class="about-right bg-white rounded-xl shadow-md p-8 text-center opacity-0 translate-x-8 transition-all duration-700 ease-out delay-150"
      >
        <p class="text-xs tracking-[0.3em] uppercase text-brand-accent mb-2">
          Unit Two
        </p>
        <h3 class="font-headers text-2xl mb-1">Second Floor</h3>
        <div class="w-8 h-0.5 rounded-full bg-brand-accent mx-auto my-3"></div>
        <p class="text-sm opacity-60 mb-4">
          6 Guests · 2 Bedrooms · 4 Beds · 2.5 Baths
        </p>
        <div class="text-sm space-y-1.5 opacity-80">
          <p>Bedroom 1: 1 King Bed</p>
          <p>Bedroom 2: 2 Twin Beds</p>
          <p>Common Space: 1 Sofa Bed</p>
          <p class="text-xs pt-3 opacity-60">21 stairs total to entry</p>
        </div>
      </div>
    </div>
  </Section>

  <Section background="light">
    <SectionHeader
      title="House Rules & Info"
      tagline="Stay Guidelines"
      class="text-center mx-auto"
    />

    <div class="grid lg:grid-cols-2 gap-16 items-start max-w-6xl mx-auto">
      <div
        class="reveal-card opacity-0 translate-y-5 transition-all duration-700"
      >
        <div class="pb-6 text-center">
          <div class="inline-block relative">
            <p class="text-2xl font-headers text-brand-secondary relative z-10">
              28-Night Minimum Stay
            </p>
            <div
              class="absolute -bottom-1 left-0 w-full h-3 bg-brand-accent/20 z-0"
            >
            </div>
          </div>
          <p
            class="text-[10px] uppercase tracking-[0.3em] text-brand-secondary/40 font-bold mt-4"
          >
            No Hidden Costs or Booking Fees
          </p>
        </div>

        <div
          class="bg-stone-50 rounded-xl p-8 mb-10 border border-stone-100 shadow-sm"
        >
          <div class="grid grid-cols-2 divide-x divide-stone-200 text-center">
            <div class="px-4">
              <p
                class="text-[10px] uppercase tracking-[0.2em] text-brand-accent mb-2 font-bold"
              >
                Check In
              </p>
              <p class="font-headers text-3xl text-brand-secondary">4:00 PM</p>
            </div>
            <div class="px-4">
              <p
                class="text-[10px] uppercase tracking-[0.2em] text-brand-accent mb-2 font-bold"
              >
                Check Out
              </p>
              <p class="font-headers text-3xl text-brand-secondary">10:00 AM</p>
            </div>
          </div>
        </div>

        <div
          class="flex flex-wrap justify-center gap-x-10 gap-y-4 text-[11px] mb-12 px-2 uppercase tracking-[0.2em] font-bold text-brand-secondary/50"
        >
          <p class="flex items-center gap-2">✕ No Smoking</p>
          <p class="flex items-center gap-2">✕ No Pets</p>
          <p class="flex items-center gap-2">✕ No Parties</p>
        </div>

        <div
          class="grid sm:grid-cols-3 gap-8 mb-12 text-center border-y border-stone-100 py-10 px-4"
        >
          <div class="space-y-2">
            <p
              class="text-[10px] uppercase tracking-widest text-brand-accent font-bold"
            >
              Parking
            </p>
            <p class="text-sm text-brand-secondary/80 leading-relaxed">
              1 free pass per unit provided for nearby garage
            </p>
          </div>
          <div class="space-y-2 border-x border-stone-100 px-4">
            <p
              class="text-[10px] uppercase tracking-widest text-brand-accent font-bold"
            >
              Guest Access
            </p>
            <p class="text-sm text-brand-secondary/80 leading-relaxed">
              Private front door entry for all units
            </p>
          </div>
          <div class="space-y-2">
            <p
              class="text-[10px] uppercase tracking-widest text-brand-accent font-bold"
            >
              Stairs
            </p>
            <p class="text-sm text-brand-secondary/80 leading-relaxed">
              4 steps to 1st floor <br /> 21 steps to 2nd floor
            </p>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div
            class="bg-brand-secondary rounded-xl p-6 border border-brand-secondary shadow-lg"
          >
            <p
              class="text-[10px] tracking-[0.3em] uppercase text-brand-accent mb-3 font-bold"
            >
              Policy
            </p>
            <h3 class="font-headers text-lg mb-4 text-white">Cancellation</h3>
            <ul class="text-xs space-y-3 text-white">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-accent"></span>
                <span><strong>4 Weeks:</strong> Full Refund</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-accent"></span>
                <span><strong>2 Weeks:</strong> 50% Refund</span>
              </li>
              <li class="italic opacity-60 mt-2">*No refunds under 2 weeks*</li>
            </ul>
          </div>

          <div
            class="bg-brand-secondary rounded-xl p-6 flex flex-col justify-between border border-brand-primary/10 shadow-lg"
          >
            <div>
              <p
                class="text-[9px] uppercase tracking-widest text-brand-accent font-bold mb-1"
              >
                On-Site Concierge
              </p>
              <h3 class="font-headers text-2xl text-white">Bopha</h3>
            </div>
            <p class="text-xs leading-relaxed mt-4 text-white">
              Available for check-in assistance and local Key West
              recommendations.
            </p>
          </div>
        </div>
      </div>

      <div
        class="reveal-card opacity-0 translate-y-5 transition-all duration-700 delay-200 relative lg:sticky lg:top-32"
      >
        <Image
          src={frontRightDoor}
          alt="Sweet Caroline Seaport Entry"
          width={800}
          height={1000}
          class="rounded-lg shadow-2xl w-full aspect-4/5 object-cover"
        />
      </div>
    </div>
  </Section>

  <Section>
    <SectionHeader title="Amenities" tagline="What We Offer">
      <p class="text-sm leading-relaxed max-w-xl mx-auto opacity-70">
        Sweet Caroline Seaport offers you everything you need, and more, to have
        a comfortable, luxurious stay in Key West. To take your experience to
        the next level, our Concierge affords an astonishing array of
        personalized services. Upon your arrival, our concierge, Bopha, will
        introduce you to the very best Key West has to offer.
      </p>
      <p class="text-sm leading-relaxed max-w-xl mx-auto opacity-70">
        With our local knowledge, you can create a true connection with our
        island community, and make your stay a once-in-a-lifetime experience.
      </p>
    </SectionHeader>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
      {
        amenityCategories.map((cat, catIdx) => (
          <div
            class="reveal-card bg-white rounded-xl shadow-md p-6 opacity-0 translate-y-5 transition-all duration-700 hover:shadow-lg hover:-translate-y-1 border border-stone-200"
            style={`transition-delay: ${catIdx * 100}ms`}
          >
            <p class="text-[10px] tracking-[0.25em] uppercase text-brand-accent mb-1 font-bold">
              Included
            </p>
            <h3 class="font-headers text-lg mb-3 text-brand-secondary">
              {cat.title}
            </h3>
            <div class="w-8 h-0.5 rounded-full bg-brand-accent mb-6" />
            <div class="space-y-4">
              {cat.items.map((item) => (
                <div class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-brand-primary/10 flex items-center justify-center shrink-0">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-brand-secondary"
                      set:html={iconPaths[item.icon]}
                    />
                  </div>
                  <span class="text-xs text-brand-secondary/80 leading-tight pt-1">
                    {item.label}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 max-w-4xl mx-auto border-t border-stone-200 pt-8">
      <div class="flex flex-wrap justify-center gap-x-12 gap-y-4">
        {
          [
            "Smoke Alarm",
            "Carbon Monoxide Alarm",
            "Fire Extinguisher",
            "First Aid Kit",
          ].map((safety) => (
            <div class="flex items-center gap-2 text-[10px] uppercase tracking-widest text-brand-secondary/40 font-bold">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-accent"
              >
                <>
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
                  <path d="m9 12 2 2 4-4" />
                </>
              </svg>
              {safety}
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <Section background="light">
    <SectionHeader title="Pricing" tagline="Rates">
      <p class="text-sm leading-relaxed max-w-xl mx-auto opacity-70">
        Pricing is for the entire unit regardless of number of guests. $1,000
        security deposit per rental.<br />
        5% Local Tax and 7.5% State Tax collected. No hidden costs or booking fees.<br
        />
        Please see our Availability page to view available dates for booking.
      </p>
    </SectionHeader>

    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {
        [
          { title: "1st Floor · 3 Bedroom", data: firstFloorPricing },
          { title: "2nd Floor · 2 Bedroom", data: secondFloorPricing },
        ].map((unit, idx) => (
          <div
            class="reveal-card bg-white rounded-xl shadow-md overflow-hidden opacity-0 translate-y-5 transition-all duration-700"
            style={`transition-delay: ${idx * 150}ms`}
          >
            <div class="bg-brand-secondary text-white text-center py-6 px-4">
              <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-1">
                Nightly Rate
              </p>
              <h3 class="font-headers text-xl">{unit.title}</h3>
            </div>
            <div class="divide-y divide-stone-100">
              {unit.data.map((row) => (
                <div class="flex items-center justify-between px-6 py-3 text-sm hover:bg-brand-primary/5 transition-colors">
                  <span class="opacity-60">{row.period}</span>
                  <span class="font-semibold">{row.rate}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="text-center mt-12">
      <Button href="/availability" variant="primary" size="md">
        Check Availability
      </Button>
    </div>
  </Section>

  <CTA />
</Layout>

<script>
  const cardObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.classList.add("opacity-100", "translate-y-0");
          el.classList.remove("opacity-0", "translate-y-5");
          cardObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: "-80px" },
  );

  const slideObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.classList.add("opacity-100", "translate-x-0");
          el.classList.remove("opacity-0", "-translate-x-8", "translate-x-8");
          slideObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: "-100px" },
  );

  document
    .querySelectorAll(".reveal-card")
    .forEach((el) => cardObserver.observe(el));
  document
    .querySelectorAll(".about-left, .about-right")
    .forEach((el) => slideObserver.observe(el));
</script>
