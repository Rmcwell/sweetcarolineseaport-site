---
// src/pages/404.astro
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
---
<Layout title="Page Not Found" description="This page doesn't exist.">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-6xl font-bold text-brand-500">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-gray-900">Page Not Found</h1>
    <p class="mt-2 text-gray-500">The page you're looking for doesn't exist or was moved.</p>
    <Button href="/" variant="primary" size="lg" class="mt-8">Go Home</Button>
  </div>
</Layout>
