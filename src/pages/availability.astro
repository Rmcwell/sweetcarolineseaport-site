---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/UI/Section.astro";
import CTA from "../components/CTA.astro";

const pageTitle = "Availability";
const metaDescription =
  "View availability of our luxury 1st and 2nd floor units in Key West.";
---

<Layout title={pageTitle} description={metaDescription}>
  <PageHero
    title="Availability"
    subtitle="Experience the island like a local with an extended stay in our historic seaport residence."
    tagline="Monthly Stays"
  />

  <Section background="white">
    <div class="flex justify-center mb-12">
      <div
        class="inline-flex rounded-lg bg-stone-100 p-1.5 gap-1 border border-stone-200"
        role="tablist"
      >
        <button
          id="tab-first"
          role="tab"
          aria-selected="true"
          aria-controls="panel-first"
          data-target="panel-first"
          class="tab-btn px-6 py-2.5 rounded-md text-xs uppercase tracking-widest font-bold transition-all duration-300 bg-brand-secondary text-white shadow-md cursor-pointer"
        >
          1st Floor · 3BR
        </button>
        <button
          id="tab-second"
          role="tab"
          aria-selected="false"
          aria-controls="panel-second"
          data-target="panel-second"
          class="tab-btn px-6 py-2.5 rounded-md text-xs uppercase tracking-widest font-bold transition-all duration-300 text-stone-500 hover:text-brand-secondary cursor-pointer"
        >
          2nd Floor · 2BR
        </button>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 w-full">
      <div
        id="panel-first"
        role="tabpanel"
        aria-labelledby="tab-first"
        class="tab-panel"
      >
        <div class="mb-4 pb-4">
          <p
            class="text-xs uppercase tracking-widest font-bold text-brand-accent mb-3"
          >
            3 Bedrooms · 5 Beds · 3 Baths
          </p>
          <h2 class="text-2xl md:text-4xl font-serif mb-6 leading-tight">
            1st Floor Unit
          </h2>
          <div class="flex flex-wrap gap-3">
            <span
              class="inline-flex items-center gap-2 bg-stone-100 text-stone-700 text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded-full"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                ></path>
              </svg>
              Up to 8 Guests
            </span>
            <span
              class="inline-flex items-center gap-2 bg-red-50 text-red-700 text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded-full"
            >
              <span class="w-2 h-2 rounded-full bg-red-500"></span>
              Red = Booked
            </span>
          </div>
        </div>

        <div class="bg-stone-50 rounded-lg p-6 mb-8 border border-stone-200/60">
          <p class="text-stone-700 leading-relaxed mb-4">
            Ready to secure your stay? Our historic seaport residence is managed
            with a personal touch to ensure your island experience is seamless.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center font-bold uppercase tracking-wider text-xs hover:gap-2 transition-all"
          >
            Contact Us to Book Your Dates
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 ml-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
        <div
          class="relative w-full overflow-hidden rounded-xl border border-stone-200 shadow-sm h-112 sm:h-auto sm:aspect-4/3"
        >
          <iframe
            src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FNew_York&showPrint=0&src=NzI0Y2Fyb2xpbmVzdEBnbWFpbC5jb20&src=dHJ0aTBndGduajczOTJkbmJoZXN0cWhsZjBAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&color=%234285f4&color=%23ff0000"
            class="border-0 absolute top-0 left-0 w-[160%] h-[160%] origin-top-left scale-[0.625] sm:scale-100 sm:w-full sm:h-full sm:relative sm:top-auto sm:left-auto"
          ></iframe>
        </div>
      </div>

      <div
        id="panel-second"
        role="tabpanel"
        aria-labelledby="tab-second"
        class="tab-panel hidden"
      >
        <div class="mb-4 pb-4">
          <p
            class="text-xs uppercase tracking-widest text-brand-accent font-bold mb-3"
          >
            2 Bedrooms · 4 Beds · 2.5 Baths
          </p>
          <h2 class="text-2xl md:text-4xl font-serif mb-6 leading-tight">
            2nd Floor Unit
          </h2>
          <div class="flex flex-wrap gap-3">
            <span
              class="inline-flex items-center gap-2 bg-stone-100 text-stone-700 text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded-full"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                ></path>
              </svg>
              Up to 6 Guests
            </span>
            <span
              class="inline-flex items-center gap-2 bg-red-50 text-red-700 text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded-full"
            >
              <span class="w-2 h-2 rounded-full bg-red-500"></span>
              Red = Booked
            </span>
          </div>
        </div>

        <div class="bg-stone-50 rounded-lg p-6 mb-8 border border-stone-200/60">
          <p class="text-stone-700 leading-relaxed mb-4">
            Ready to secure your stay? Our historic seaport residence is managed
            with a personal touch to ensure your island experience is seamless.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center font-bold uppercase tracking-wider text-xs hover:gap-2 transition-all"
          >
            Contact Us to Book Your Dates
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 ml-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
        <div
          class="relative w-full overflow-hidden rounded-xl border border-stone-200 shadow-sm h-112 sm:h-auto sm:aspect-4/3"
        >
          <iframe
            src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FNew_York&showPrint=0&src=MmxmczZxbGZyMGcxbWo3ZTg3ajBxMWhvNWtAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&src=dnZrdjFxZXRwamg1bGtsNXE2MXVyOTQxY3NAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&color=%234285f4&color=%23ff0000"
            class="border-0 absolute top-0 left-0 w-[160%] h-[160%] origin-top-left scale-[0.625] sm:scale-100 sm:w-full sm:h-full sm:relative sm:top-auto sm:left-auto"
          ></iframe>
        </div>
      </div>
    </div>
  </Section>
  <CTA />
</Layout>

<script>
  // Tab Switching Logic
  const tabs = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const panels = document.querySelectorAll<HTMLElement>(".tab-panel");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => {
        t.setAttribute("aria-selected", "false");
        t.classList.remove("bg-brand-secondary", "text-white", "shadow-md");
        t.classList.add("text-stone-500");
      });
      panels.forEach((p) => p.classList.add("hidden"));

      tab.setAttribute("aria-selected", "true");
      tab.classList.add("bg-brand-secondary", "text-white", "shadow-md");
      tab.classList.remove("text-stone-500");

      const targetId = tab.dataset.target!;
      document.getElementById(targetId)?.classList.remove("hidden");
    });
  });
</script>
