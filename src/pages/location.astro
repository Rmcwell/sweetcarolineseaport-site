---
import { Image } from "astro:assets";
import historicSeaport from "../assets/historicSeaport.jpg";
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/UI/Section.astro";
import SectionHeader from "../components/UI/SectionHeader.astro";

const landmarks = [
  {
    icon: "anchor",
    name: "Key West Seaport",
    distance: "1 min",
    desc: "Historic harbor right at your doorstep",
  },
  {
    icon: "ship",
    name: "Schooner Wharf Bar",
    distance: "2 min",
    desc: "Legendary waterfront bar & live music venue",
  },
  {
    icon: "navigation",
    name: "Duval Street",
    distance: "3 min",
    desc: "The iconic heart of Key West nightlife",
  },
  {
    icon: "utensils-crossed",
    name: "Seaport Dining",
    distance: "2 min",
    desc: "World-class restaurants in the district",
  },
  {
    icon: "map-pin",
    name: "Mallory Square",
    distance: "8 min",
    desc: "Famous sunset celebration & street performers",
  },
  {
    icon: "music",
    name: "Live Music",
    distance: "5 min",
    desc: "Nightly entertainment along the water",
  },
  {
    icon: "tree-palm",
    name: "Fort Zachary Beach",
    distance: "12 min",
    desc: "Key West's finest beach & state park",
  },
  {
    icon: "shopping-bag",
    name: "Local Boutiques",
    distance: "3 min",
    desc: "Unique shops & art galleries",
  },
];

const iconPaths: Record<string, string> = {
  anchor: `<path d="M12 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/><path d="M12 8v14"/><path d="M5 15H2a10 10 0 0 0 20 0h-3"/>`,
  ship: `<path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.61 7.76"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/><path d="M12 10v4"/><path d="M12 3v4"/>`,
  navigation: `<polygon points="3 11 22 2 13 21 11 13 3 11"/>`,
  "utensils-crossed": `<path d="m16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8"/><path d="M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7"/><path d="m2.1 21.8 6.4-6.3"/><path d="m19 5-7 7"/>`,
  "map-pin": `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
  music: `<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>`,
  "tree-palm": `<path d="M13 8c0-2.76-2.46-5-5.5-5S2 5.24 2 8h2l1-1 1 1h4"/><path d="M13 7.14A5.82 5.82 0 0 1 16.5 6c3.04 0 5.5 2.24 5.5 5h-3l-1-1-1 1h-3"/><path d="M5.89 9.71c-2.15 2.15-2.3 5.47-.35 7.43l4.24-4.25.7-.7.71-.71 2.12-2.12c-1.95-1.96-5.27-1.8-7.42.35z"/><path d="M11 15.5c.5 2.5-.17 4.5-1 6.5h4c2-5.5-.5-12-1-14"/>`,
  "shopping-bag": `<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>`,
};

const pageTitle = "Location";
const metaDescription =
  "Discover the best of Key West's historic seaport district.";
---

<Layout title={pageTitle} description={metaDescription}>
  <PageHero
    title="Prime Location"
    subtitle="724 Caroline Street is in the heart of Key West's most coveted neighborhood."
    tagline="Seaport District"
  />

  <Section>
    <SectionHeader title="Key West, Florida" tagline="USA" />

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-5">
        <div class="relative group">
          <div
            class="absolute -top-4 -right-4 w-24 h-24 bg-brand-secondary/5 rounded-full -z-10 group-hover:scale-110 transition-transform duration-700"
          >
          </div>

          <div
            class="rounded-2xl overflow-hidden shadow-2xl border-4 border-white transition-transform duration-500"
          >
            <Image
              src={historicSeaport}
              alt="View of the Key West Historic Seaport"
              class="w-full h-150 object-cover object-left"
            />
          </div>

          <div
            class="absolute top-6 -left-6 bg-brand-secondary text-white px-6 py-3 rounded-lg shadow-xl"
          >
            <p class="text-xs font-bold uppercase tracking-widest">
              Historic Seaport District
            </p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-7">
        <h3 class="font-heading text-3xl text-brand-secondary mb-6 italic">
          The Island's Best, Just Beyond Your Door.
        </h3>

        <div class="space-y-6 font-body text-stone-600 leading-relaxed text-lg">
          <p>
            Our area of Caroline St has been completely redone with a new road
            and all new landscaping, sidewalks, and extensive street lighting.
          </p>
          <p>
            <strong class="text-brand-secondary">500 feet</strong> away is the Key
            West Bight historical seaport with many restaurants and bars—most with
            happy hours: Schooners Wharf, Prime Steak House, Half Shell Raw Bar, Alonzo's,
            A&B Lobster House, Bo's Fish Wagon, and Pepe's (The oldest restaurant
            in Key West), The Cuban Coffee Queen and others.
          </p>
          <p>
            Most of the sunset cruises leave from here: America 2.0, Sebago and
            Fury. Water sports charters, including snorkeling and scuba diving,
            depart from this bight as well.
          </p>
          <p>
            <strong class="text-brand-secondary">Two blocks</strong> away is Duval
            Street with famous bars such as Sloppy Joes, Irish Kevins, Ricks, and
            The Bull.
          </p>
          <p>
            Sweet Caroline Seaport is within walking distance to the Key West
            Express ferry terminal which travels round trip to Ft Myers and
            Marco Island.
          </p>
        </div>

        <div
          class="grid grid-cols-3 gap-4 mt-10 pt-8 border-t border-stone-100"
        >
          <div>
            <p class="text-brand-secondary font-heading text-2xl font-bold">
              500ft
            </p>
            <p class="text-xs uppercase tracking-widest text-stone-400">
              To the Bight
            </p>
          </div>
          <div>
            <p class="text-brand-secondary font-heading text-2xl font-bold">
              2 Blocks
            </p>
            <p class="text-xs uppercase tracking-widest text-stone-400">
              To Duval St
            </p>
          </div>
          <div>
            <p class="text-brand-secondary font-heading text-2xl font-bold">
              0
            </p>
            <p class="text-xs uppercase tracking-widest text-stone-400">
              Cars Needed
            </p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section background="white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-7">
          <div
            class="map-card sticky top-32 rounded-2xl overflow-hidden h-160 shadow-2xl shadow-brand-secondary/10 border-4 border-white opacity-0 translate-x-8 transition-all duration-1000"
          >
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d17000!2d-81.80124701225971!3d24.55996971962419!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d1b77080a8b8d5%3A0xd674437822ad2422!2sSweet%20Caroline%20Seaport!5e1!3m2!1sen!2sus!4v1774468051044!5m2!1sen!2sus"
              class="w-full h-full grayscale-[0.2] contrast-[1.1]"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="max-w-2xl">
            <h2
              class="font-heading text-3xl md:text-4xl text-brand-secondary mb-6 italic"
            >
              Park the car. Walk everywhere.
            </h2>
            <p class="font-body text-stone-600 leading-relaxed mb-10 text-lg">
              Sweet Caroline Seaport sits steps from the historic seaport, the
              legendary Schooner Wharf Bar, world-class dining, and the island's
              best attractions. Everything you need is within walking distance.
            </p>

            <div class="space-y-3">
              {
                landmarks.map((lm, i) => (
                  <div
                    class="landmark-card flex items-center gap-5 p-5 rounded-xl border border-stone-100 bg-stone-50/50 group hover:bg-white hover:shadow-xl hover:shadow-stone-200/50 transition-all duration-500 opacity-0 -translate-x-5"
                    style={`transition-delay: ${i * 60}ms`}
                  >
                    <div class="w-12 h-12 rounded-full bg-white shadow-sm border border-stone-100 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform duration-500">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="text-brand-secondary"
                        set:html={iconPaths[lm.icon]}
                      />
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between mb-0.5">
                        <p class="font-heading text-base text-brand-secondary font-semibold">
                          {lm.name}
                        </p>
                        <span class="font-body text-[10px] uppercase tracking-widest font-bold text-brand-secondary bg-brand-secondary/5 px-2 py-1 rounded">
                          {lm.distance} walk
                        </span>
                      </div>
                      <p class="font-body text-sm text-stone-500">{lm.desc}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("opacity-100", "translate-x-0");
          entry.target.classList.remove(
            "opacity-0",
            "-translate-x-5",
            "translate-x-8",
          );
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 },
  );

  document
    .querySelectorAll(".landmark-card, .map-card")
    .forEach((el) => observer.observe(el));
</script>
