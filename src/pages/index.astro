---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Section from "../components/UI/Section.astro";
import CTA from "../components/CTA.astro";
import frontVertical from "../assets/frontVertical.webp"
import beachImage from "../assets/beach.webp"

const firstFloorStats = [
  { value: "8", label: "Guests" },
  { value: "3", label: "Bedrooms" },
  { value: "3", label: "Baths" },
];

const secondFloorStats = [
  { value: "6", label: "Guests" },
  { value: "2", label: "Bedrooms" },
  { value: "2.5", label: "Baths" },
];
---

<Layout title="Home" description="Welcome to Sweet Caroline Seaport — Luxury Key West Vacation Rentals.">
  
  <section id="home" class="relative h-screen min-h-150 w-full overflow-hidden bg-gray-900">
  <Image
    src={beachImage}
    alt="Sweet Caroline Seaport — luxury Key West vacation rental at golden hour"
    class="absolute inset-0 h-full w-full object-cover -scale-x-100"
    loading="eager"
    fetchpriority="high"
  />

  <div class="absolute inset-0 bg-linear-to-r from-black/80 via-black/60 to-black/20"></div>

  <div class="relative z-10 flex h-full items-center">
    <div class="container mx-auto px-6">
      <div 
        id="hero-content" 
        class="max-w-2xl transform opacity-0 translate-y-8 transition-all duration-1000 ease-out"
      >
        <p class="mb-4 text-sm font-light tracking-[0.35em] uppercase text-white/80">
          724 Caroline Street · Key West, Florida
        </p>
        
        <h1 class="mb-6 font-headers text-5xl leading-tight text-white md:text-7xl">
          <span class="italic text-brand-accent">Affordable</span> Luxury in <span class="italic text-brand-accent">Tropical</span> Paradise
        </h1>

        <div class="mb-6 h-px w-16 bg-brand-primary"></div>

        <p class="mb-8 max-w-lg text-lg leading-relaxed text-white/90 font-light">
          A newly renovated historical home in the heart of Key West. Where timeless charm meets modern elegance.
        </p>

        <div class="flex flex-wrap gap-4">
          <Button href="/availability" variant="primary" size="md">
            Check Availability
          </Button>
          <Button href="/about" variant="secondaryLight" size="md">
            Explore Property
          </Button>
        </div>
      </div>
    </div>
  </div>

  <div
    id="scroll-indicator"
    class="absolute bottom-10 left-1/2 z-10 -translate-x-1/2 animate-bounce"
    aria-hidden="true"
  >
    <div class="flex h-12 w-7 items-start justify-center rounded-full border-2 border-white/30 p-2">
      <div class="h-2 w-1.5 rounded-full bg-amber-400"></div>
    </div>
  </div>
</section>

  <Section>
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <div class="about-left opacity-0 -translate-x-8 transition-all duration-700 ease-out">
        <p class="text-sm tracking-[0.3em] uppercase text-brand-accent font-semibold mb-3">
          About the Property
        </p>
        <h2 class="text-4xl md:text-5xl mb-6 leading-tight">
          A Key West Estate <br />
          <span class="italic text-brand-primary">Like No Other</span>
        </h2>
        <div class="w-16 h-1 bg-brand-accent mb-6 rounded-full"></div>
        
        <p class="opacity-80 leading-relaxed mb-4">
          Sweet Caroline Seaport is a beautifully renovated historical home
          located in the heart of Key West's vibrant Seaport District. Just steps
          from the waterfront, world-class dining, and the legendary Duval Street.
        </p>
        <div class="space-y-10">
          <div>
            <p class="text-xs tracking-[0.25em] uppercase text-brand-accent/80 mb-4 font-bold">First Floor</p>
            <div class="grid grid-cols-3 gap-6">
              {firstFloorStats.map((stat) => (
                <div class="text-left border-l border-brand-primary/30 pl-4">
                  <p class="text-4xl font-headers text-brand-secondary">{stat.value}</p>
                  <p class="text-[10px] tracking-[0.2em] uppercase opacity-50 mt-1">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>

          <div>
            <p class="text-xs tracking-[0.25em] uppercase text-brand-accent/80 mb-4 font-bold">Second Floor</p>
            <div class="grid grid-cols-3 gap-6">
              {secondFloorStats.map((stat) => (
                <div class="text-left border-l border-brand-primary/30 pl-4">
                  <p class="text-4xl font-headers text-brand-secondary">{stat.value}</p>
                  <p class="text-[10px] tracking-[0.2em] uppercase opacity-50 mt-1">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="about-right relative opacity-0 translate-x-8 transition-all duration-700 ease-out delay-200">      
        <Image
          src={frontVertical}
          alt="Elegant coastal Key West, FL House"
          width={600}
          height={768}
          loading="lazy"
          class="rounded-lg shadow-2xl w-full object-cover aspect-3/4"
        />
      </div>
    </div>
  </Section>

  <CTA />

</Layout>

<script>
//HERO
  // Entrance animation logic
  const heroContent = document.getElementById("hero-content");
  
  if (heroContent) {
    // Wait for the next frame to ensure the browser has registered the starting state
    requestAnimationFrame(() => {
        // We remove the starting states and add the ending states
        heroContent.classList.remove("opacity-0", "translate-y-8");
        heroContent.classList.add("opacity-100", "translate-y-0");
    });
  }


  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.classList.add("opacity-100", "translate-x-0");
          el.classList.remove("opacity-0", "-translate-x-8", "translate-x-8");
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: "-100px" }
  );
 
  document.querySelectorAll(".about-left, .about-right").forEach((el) =>
    observer.observe(el)
  );
</script>