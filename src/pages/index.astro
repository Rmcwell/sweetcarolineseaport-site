---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Section from "../components/UI/Section.astro";
import CTA from "../components/CTA.astro";
import frontVertical from "../assets/frontVertical.webp";
import beachImage from "../assets/beach.webp";

const firstFloorStats = [
  { value: "8", label: "Guests" },
  { value: "3", label: "Bedrooms" },
  { value: "3", label: "Baths" },
];

const secondFloorStats = [
  { value: "6", label: "Guests" },
  { value: "2", label: "Bedrooms" },
  { value: "2.5", label: "Baths" },
];

const metaDescription =
  "Welcome to Sweet Caroline Seaport — Luxury Key West Vacation Rentals.";
---

<Layout description={metaDescription}>
  <section
    id="home"
    class="relative h-screen min-h-150 w-full overflow-hidden bg-gray-900"
  >
    <Image
      src={beachImage}
      alt="Sweet Caroline Seaport — luxury Key West vacation rental at golden hour"
      class="absolute inset-0 h-full w-full object-cover -scale-x-100"
      loading="eager"
      fetchpriority="high"
    />

    <div
      class="absolute inset-0 bg-linear-to-r from-black/80 via-black/60 to-black/20"
    >
    </div>

    <div class="relative z-10 flex h-full items-center">
      <div class="container mx-auto px-6">
        <div
          id="hero-content"
          class="max-w-2xl transform opacity-0 translate-y-8 transition-all duration-1000 ease-out"
        >
          <p
            class="mb-4 text-sm font-light tracking-[0.35em] uppercase text-white/80"
          >
            28 Night Minimum starting at $214/night
          </p>

          <h1
            class="mb-6 font-headers text-5xl leading-tight text-white md:text-7xl"
          >
            Affordable Luxury in <span class="italic text-brand-accent"
              >Key West, Florida</span
            >
          </h1>

          <div class="mb-6 h-px w-16 bg-brand-primary"></div>

          <p
            class="mb-8 max-w-lg text-lg leading-relaxed text-white/90 font-light"
          >
            A newly renovated historical home in the heart of Historical Key
            West. Where timeless charm meets modern elegance.
          </p>

          <div class="flex flex-wrap gap-4">
            <Button href="/availability" variant="primary" size="md">
              Check Availability
            </Button>
            <Button href="/about" variant="secondaryLight" size="md">
              Explore the Property
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Section>
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div
        class="about-left opacity-0 -translate-x-8 transition-all duration-700 ease-out"
      >
        <p
          class="text-sm tracking-[0.3em] uppercase text-brand-accent font-semibold mb-3"
        >
          About the Property
        </p>
        <h2 class="text-4xl md:text-5xl mb-6 leading-tight">
          A Key West Estate <br />
          <span class="italic text-brand-primary">Like No Other</span>
        </h2>
        <div class="w-16 h-1 bg-brand-accent mb-6 rounded-full"></div>

        <p class="opacity-80 leading-relaxed mb-4">
          Sweet Caroline Seaport is a beautifully renovated historical home
          located in the heart of Key West's vibrant Seaport District. Just
          steps from the waterfront, world-class dining, and the legendary Duval
          Street.
        </p>

        <div class="space-y-10">
          <div>
            <p
              class="text-xs tracking-[0.25em] uppercase text-brand-accent/80 mb-4 font-bold"
            >
              First Floor
            </p>
            <div class="grid grid-cols-3 gap-6">
              {
                firstFloorStats.map((stat) => (
                  <div class="text-left border-l border-brand-primary/30 pl-4">
                    <p class="text-4xl font-headers text-brand-secondary">
                      {stat.value}
                    </p>
                    <p class="text-[10px] tracking-[0.2em] uppercase opacity-50 mt-1">
                      {stat.label}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>

          <div>
            <p
              class="text-xs tracking-[0.25em] uppercase text-brand-accent/80 mb-4 font-bold"
            >
              Second Floor
            </p>
            <div class="grid grid-cols-3 gap-6">
              {
                secondFloorStats.map((stat) => (
                  <div class="text-left border-l border-brand-primary/30 pl-4">
                    <p class="text-4xl font-headers text-brand-secondary">
                      {stat.value}
                    </p>
                    <p class="text-[10px] tracking-[0.2em] uppercase opacity-50 mt-1">
                      {stat.label}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Concierge + Minimum Stay -->
        <div class="mt-10 pt-10 border-t border-brand-primary/20 space-y-4">
          <div class="flex items-start gap-4">
            <div
              class="shrink-0 w-9 h-9 rounded-full bg-brand-primary/10 flex items-center justify-center mt-0.5"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-primary"
              >
                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <div>
              <p
                class="text-xs tracking-[0.25em] uppercase text-brand-accent/80 font-bold mb-1"
              >
                Concierge Service
              </p>
              <p class="text-sm opacity-70 leading-relaxed">
                Our concierge, Bopha, will introduce you to the very best Key
                West has to offer; creating a true connection with our island
                community and making your stay a once-in-a-lifetime experience.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="shrink-0 w-9 h-9 rounded-full bg-brand-accent/10 flex items-center justify-center mt-0.5"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-accent"
              >
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
                <line x1="16" x2="16" y1="2" y2="6"></line>
                <line x1="8" x2="8" y1="2" y2="6"></line>
                <line x1="3" x2="21" y1="10" y2="10"></line>
              </svg>
            </div>
            <div>
              <p
                class="text-xs tracking-[0.25em] uppercase text-brand-accent/80 font-bold mb-1"
              >
                28-Night Minimum Stay
              </p>
              <p class="text-sm opacity-70 leading-relaxed">
                Sweet Caroline Seaport is designed for extended stays of 28
                nights or more, giving you the time to truly experience island
                life.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="about-right relative opacity-0 translate-x-8 transition-all duration-700 ease-out delay-200"
      >
        <Image
          src={frontVertical}
          alt="Elegant coastal Key West, FL House"
          width={600}
          height={768}
          loading="lazy"
          class="rounded-lg shadow-2xl w-full object-cover aspect-3/4"
        />
      </div>
    </div>
  </Section>

  <CTA />
</Layout>

<script>
  const heroContent = document.getElementById("hero-content");

  if (heroContent) {
    requestAnimationFrame(() => {
      heroContent.classList.remove("opacity-0", "translate-y-8");
      heroContent.classList.add("opacity-100", "translate-y-0");
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.classList.add("opacity-100", "translate-x-0");
          el.classList.remove("opacity-0", "-translate-x-8", "translate-x-8");
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: "-100px" },
  );

  document
    .querySelectorAll(".about-left, .about-right")
    .forEach((el) => observer.observe(el));
</script>
